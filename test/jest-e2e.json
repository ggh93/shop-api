{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testMatch": ["**/test/**/*.e2e-spec.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "modulePathIgnorePatterns": ["<rootDir>/.claude/"],
  "testPathIgnorePatterns": ["<rootDir>/.claude/"],
  "forceExit": true,
  "detectOpenHandles": true,
  "testTimeout": 30000
}
